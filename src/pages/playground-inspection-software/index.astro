const faqs = [
  {
    q: "Do I actually need playground inspection software, or is paper enough?",
    a: "Paper still works for a single site with a single inspector carrying out low-frequency inspections. Above that threshold — multiple sites, multiple inspectors, frequent routine checks, or any volume of defect tracking — the cost of paper in missed records, lost time, and weak audit trails starts to exceed the cost of software. The tipping point for most UK operators sits somewhere between one and three sites. For independent RPII inspectors doing commercial work, software has become the professional standard regardless of site count, because the time saved on post-inspection admin pays for the subscription within the first few inspections.",
  },
  {
    q: "What&rsquo;s the difference between playground inspection software and generic asset management systems?",
    a: "Generic asset management systems treat a playground as a row in a spreadsheet — they can record that an inspection happened and attach a document, but they do not understand the structure of a BS EN 1176 inspection. Purpose-built playground inspection software knows about the three inspection tiers, the risk rating model, critical fall height measurement, surfacing assessment, and the reporting conventions UK procurement expects. Either approach can satisfy the basic compliance requirement; only purpose-built software produces reports that read like they came from a professional inspection practice.",
  },
  {
    q: "Should playground inspection software work offline?",
    a: "Yes. Many UK inspection sites have unreliable mobile data — rural parks, housing estate interiors, even urban sites in signal shadows. Software that requires connectivity for basic inspection functions (dictation, photo capture, defect entry) will fail at the moment of use. Offline-first is the 2026 professional standard: every function works without signal, with automatic sync when connection returns. Any evaluation of playground inspection software should include a real on-site test in a low-signal location.",
  },
  {
    q: "Is voice dictation reliable enough for formal inspection reports?",
    a: "For modern implementations, yes. Voice dictation does not replace the inspector&rsquo;s judgement; it captures the inspector&rsquo;s words more efficiently than typing. The critical thing is that dictated output is structured into the correct report section, not dumped as a free-text blob. Good systems recognise which item of equipment is being described, which defect category is being discussed, and apply the correct risk rating from the inspector&rsquo;s spoken assessment. The inspector remains responsible for the report&rsquo;s accuracy — the software handles the capture.",
  },
  {
    q: "How much should playground inspection software cost?",
    a: "Subscription pricing for UK-focused playground inspection software typically falls in the low hundreds of pounds per month for small teams, with enterprise-scale tooling for large authorities priced higher. Be cautious of quotes significantly above or below this band. Very cheap tools are usually repurposed generic software that lacks BS EN 1176 structure; very expensive tools often embed inspection services that an independent RPII inspector does not need. The total cost calculation should include subscription plus time saved on post-inspection admin — the latter usually dominates the former for commercial inspectors.",
  },
  {
    q: "Can I import my existing site register and inspection history?",
    a: "Good playground inspection software accepts bulk import of site registers and asset lists from spreadsheets or CSV. Historic reports are typically attached as reference PDFs rather than reconstructed inside the new system — the structural differences between systems make full reconstruction impractical and rarely valuable. Defect continuity (carried-forward findings) usually starts from the first inspection in the new system forward. Any vendor claiming full historic data reconstruction is worth scrutinising; claiming import of site registers and reference attachment of historic reports is realistic.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
