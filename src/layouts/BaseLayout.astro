---
/**
 * Base layout — page shell.
 *
 * Wraps every page in:
 *  - <html>/<head>/<body> with SEO meta via <SEO />
 *  - Global stylesheet
 *  - Site Header (top nav)
 *  - Page content (slot)
 *  - Site Footer
 *
 * Pages pass through the SEO props they need; everything else is consistent.
 *
 * The "skip to main content" link is for keyboard / screen-reader users to
 * bypass the nav and jump to <main>. Standard accessibility practice.
 */
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../consts";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
}

const { title, description, canonical, image, noindex, ogType } = Astro.props;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      noindex={noindex}
      ogType={ogType}
    />
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-brand-900 focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to main content
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>
