const title =
  "Impact-Attenuating Surfacing (BS EN 1176 & BS EN 1177)";
const description =
  "Impact-attenuating surfacing is the playground safety surface beneath equipment where fall height exceeds 600 mm. A guide to the materials, how they are tested to BS EN 1177, and what inspectors and specifiers look at.";
const lastUpdatedDisplay = "23 April 2026";
const lastUpdatedISO = "2026-04-23";
const datePublishedISO = "2026-04-23";
const canonical = `${SITE.url.replace(/\/$/, "")}/bs-en-1176/impact-attenuating-surfacing/`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: datePublishedISO,
  dateModified: lastUpdatedISO,
  author: {
    "@type": "Organization",
    name: ORGANISATION.legalName,
    url: SITE.url,
