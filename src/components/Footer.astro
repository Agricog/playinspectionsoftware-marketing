---
/**
 * Footer — professional, structured.
 *
 * Four-area layout:
 *   Top    — final CTA section
 *   Middle — brand block + three link columns (Who we help / Resources / Company)
 *   Bottom — copyright line
 *
 * On mobile the link columns stack under the brand block.
 *
 * The Resources column mirrors the header dropdown: all four topical
 * pillars (BS EN 1176, RPII, Playground Inspection Software, Asset Types)
 * plus the external product and in-page pricing link.
 *
 * The Company column covers the commercial and legal pages (Pricing,
 * About, Contact, Privacy, Terms).
 */
import { SITE, ORGANISATION, CTA, TRIAL } from "../consts";
const year = new Date().getFullYear();
---
<footer class="bg-brand-900 text-brand-100">
  <!-- Final CTA -->
  <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <div class="text-center">
      <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">
        Try it on your next inspection.
      </h2>
      <p class="mt-3 text-base text-brand-100">
        {TRIAL.durationDays}-day free trial. No credit card. Cancel anytime.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
        <a
          href={CTA.signUp}
          class="inline-flex w-full items-center justify-center rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-900 shadow-sm transition hover:bg-brand-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:w-auto"
        >
          Start free trial
        </a>
        <a
          href={CTA.bookDemo}
          class="inline-flex w-full items-center justify-center rounded-md border border-brand-100 px-6 py-3 text-base font-semibold text-white transition hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:w-auto"
        >
          Book a demo
        </a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-6 py-12 sm:py-16">
      <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
        <div class="text-center sm:text-left">
          <p class="text-base font-semibold text-white">{SITE.name}</p>
          <p class="mt-2 text-sm text-brand-100">
            A product by {ORGANISATION.legalName}.
          </p>
          <p class="mt-2 text-sm text-brand-100">
            UK-built playground inspection software for RPII inspectors
            and the organisations that commission them.
          </p>
        </div>

        <nav aria-label="Who we help" class="text-center sm:text-left">
          <p class="text-sm font-semibold uppercase tracking-wide text-white">
            Who we help
          </p>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a href="/for/independent-inspectors" class="transition hover:text-white">
                Independent inspectors
              </a>
            </li>
            <li>
              <a href="/for/inspection-companies" class="transition hover:text-white">
                Inspection companies
              </a>
            </li>
            <li>
              <a href="/for/local-authorities" class="transition hover:text-white">
                Local authorities
              </a>
            </li>
          </ul>
        </nav>

        <nav aria-label="Resources" class="text-center sm:text-left">
          <p class="text-sm font-semibold uppercase tracking-wide text-white">
            Resources
          </p>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a href="/bs-en-1176" class="transition hover:text-white">
                BS EN 1176
              </a>
            </li>
            <li>
              <a href="/rpii" class="transition hover:text-white">
                RPII
              </a>
            </li>
            <li>
              <a href="/playground-inspection-software" class="transition hover:text-white">
                Playground Inspection Software
              </a>
            </li>
            <li>
              <a href="/asset-types" class="transition hover:text-white">
                Asset Types
              </a>
            </li>
            <li>
              <a href={CTA.product} class="transition hover:text-white">
                Product
              </a>
            </li>
          </ul>
        </nav>

        <nav aria-label="Company" class="text-center sm:text-left">
          <p class="text-sm font-semibold uppercase tracking-wide text-white">
            Company
          </p>
          <ul class="mt-4 space-y-3 text-sm">
            <li>
              <a href="/pricing" class="transition hover:text-white">
                Pricing
              </a>
            </li>
            <li>
              <a href="/about" class="transition hover:text-white">
                About
              </a>
            </li>
            <li>
              <a href={`mailto:${ORGANISATION.email}`} class="transition hover:text-white">
                Contact
              </a>
            </li>
            <li>
              <a href="/privacy" class="transition hover:text-white">
                Privacy
              </a>
            </li>
            <li>
              <a href="/terms" class="transition hover:text-white">
                Terms
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="border-t border-white/10">
    <div class="mx-auto max-w-6xl px-6 py-6">
      <p class="text-center text-xs text-brand-100 sm:text-left">
        © {year} {ORGANISATION.legalName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
