---
/**
 * Homepage — the canonical entry point.
 *
 * Composition (top to bottom):
 *  1. Hero
 *  2. Problem (the pains)
 *  3. HowItWorks (the three-step solution)
 *  4. Features (six capabilities)
 *  5. WhoWeHelp (three persona pages: inspectors, companies, authorities)
 *  6. Standards (compliance / trust)
 *  7. PricingTeaser (£99 Team + Enterprise)
 *  8. FAQ (long-tail SEO + buyer objections)
 *
 * Header and Footer come from BaseLayout.
 *
 * IMPORTANT: noindex flag is NOT passed — this page IS for indexing now.
 * The SEO component's default behaviour is indexable; only pages that pass
 * noindex={true} are blocked from search.
 *
 * Title and description lead with the primary keyword ("playground
 * inspection software") and honestly describe the product: the inspector
 * runs the inspection, InspectVoice eliminates the admin around it.
 * No overclaim that voice dictation alone produces the inspection.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import WhoWeHelp from "../components/WhoWeHelp.astro";
import Standards from "../components/Standards.astro";
import PricingTeaser from "../components/PricingTeaser.astro";
import FAQ from "../components/FAQ.astro";
---
<BaseLayout
  title="Playground Inspection Software for UK RPII Inspectors"
  description="BS EN 1176-aligned playground inspection software for UK RPII inspectors and inspection companies. Capture findings by voice on-site, AI drafts the defect entries for your review, signed PDF ready before you leave. Offline-first. 30-day free trial."
>
  <Hero />
  <Problem />
  <HowItWorks />
  <Features />
  <WhoWeHelp />
  <Standards />
  <PricingTeaser />
  <FAQ />
</BaseLayout>
