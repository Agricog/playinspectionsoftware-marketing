---
/**
 * ContentHero — hero section for pillar and cluster content pages.
 *
 * Deliberately restrained. Long-form content pages don't need the same
 * visual weight as a marketing hero; the H1 is the star, everything else
 * is supporting metadata.
 *
 * Props:
 *   - title (required): page H1
 *   - description (required): one-sentence summary shown below H1
 *   - eyebrow: small uppercase label above the title (e.g. "The Standard")
 *   - lastUpdated: ISO date or human-readable string, rendered as metadata
 *   - readingTime: e.g. "8 min read"
 */

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  lastUpdated?: string;
  readingTime?: string;
}

const { title, description, eyebrow, lastUpdated, readingTime } = Astro.props;
---
<section class="border-b border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-4xl px-6 py-14 sm:py-20">
    {eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-brand-700">
        {eyebrow}
      </p>
    )}
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl sm:leading-[1.1]">
      {title}
    </h1>
    <p class="mt-5 text-lg leading-relaxed text-slate-600 sm:text-xl">
      {description}
    </p>
    {(lastUpdated || readingTime) && (
      <div class="mt-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500">
        {lastUpdated && (
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Last updated: {lastUpdated}</span>
          </span>
        )}
        {readingTime && (
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <span>{readingTime}</span>
          </span>
        )}
      </div>
    )}
  </div>
</section>
