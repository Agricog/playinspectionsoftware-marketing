---
/**
 * Pricing — surfaces the real numbers.
 *
 * Two cards side by side: Team (the public price, where most leads will
 * convert) and Enterprise (for councils — bespoke). Both pull from
 * PRICING constants so a price change is one-line.
 *
 * Deliberately light on feature lists here — the full feature breakdown
 * lives on the product site at sign-up. This page just needs enough to
 * answer "what does it cost?" honestly.
 */
import { CTA, PRICING, TRIAL } from "../consts";

const team = PRICING.team;
const enterprise = PRICING.enterprise;
---

<section id="pricing" class="border-b border-brand-100 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-brand-700">
        Pricing
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
        One straightforward monthly price.
      </h2>
      <p class="mt-4 text-lg text-slate-700">
        No per-inspection fees. No annual lock-in. Cancel anytime.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-4xl gap-6 sm:grid-cols-2">

      <article class="flex flex-col rounded-lg border-2 border-brand-700 bg-white p-8 shadow-sm">
        <div class="mb-6">
          <h3 class="text-xl font-semibold text-brand-900">{team.name}</h3>
          <p class="mt-1 text-sm text-slate-600">{team.audience}</p>
        </div>

        <div class="mb-6">
          <span class="text-4xl font-bold text-brand-900">
            {team.currency}{team.price}
          </span>
          <span class="text-base text-slate-700">/{team.cadence}</span>
        </div>

        <ul class="mb-8 flex-1 space-y-3 text-sm text-slate-700">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Up to {team.inspectorLimit} inspectors</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Unlimited inspections and sites</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Voice dictation + AI defect extraction</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Branded PDF reports on the device</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Offline-first capture and sync</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Email support</span>
          </li>
        </ul>

        <a
          href={CTA.signUp}
          class="inline-flex items-center justify-center rounded-md bg-brand-700 px-6 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-brand-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-700"
        >
          Start your {TRIAL.durationDays}-day free trial
        </a>
        <p class="mt-3 text-center text-xs text-slate-600">
          No credit card required
        </p>
      </article>

      <article class="flex flex-col rounded-lg border border-brand-100 bg-brand-50 p-8">
        <div class="mb-6">
          <h3 class="text-xl font-semibold text-brand-900">{enterprise.name}</h3>
          <p class="mt-1 text-sm text-slate-600">{enterprise.audience}</p>
        </div>

        <div class="mb-6">
          <span class="text-4xl font-bold text-brand-900">Bespoke</span>
        </div>

        <ul class="mb-8 flex-1 space-y-3 text-sm text-slate-700">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Unlimited inspectors and sites</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Dedicated onboarding and training</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Custom report templates</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>DPIA and DPA documentation</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Named account manager</span>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-700" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Priority support</span>
          </li>
        </ul>

        <a
          href={CTA.enterpriseContact}
          class="inline-flex items-center justify-center rounded-md border border-brand-700 bg-white px-6 py-3 text-base font-semibold text-brand-700 transition hover:bg-brand-700 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-700"
        >
          Contact us
        </a>
        <p class="mt-3 text-center text-xs text-slate-600">
          Tailored to your authority
        </p>
      </article>

    </div>
  </div>
</section>
