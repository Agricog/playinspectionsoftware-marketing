 * /rpii — pillar page.
 *
 * Second pillar in the content architecture. Complements /bs-en-1176:
 * the standard on one pillar, the certified people who work to it on the
 * other. Targets the primary SEO keyword "RPII" and long-tail variants
 * ("RPII certification", "RPII inspector", "how to become a playground
 * inspector", "RPII annual inspector", "play inspector qualification UK").
 *
 * Audience is broader than a cluster page — covers both prospective
 * inspectors (career-path queries) and operators (procurement queries).
 * The external authority link to playinspectors.com is deliberate: trust
 * signal to Google, helpful to the reader.
 *
 * Future cluster pages will live at /rpii/{grades, certification-routes,
 * cpd-and-renewal, finding-an-inspector}.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContentHero from "../../components/ContentHero.astro";
import ContentBreadcrumbs from "../../components/ContentBreadcrumbs.astro";
import ContentCTA from "../../components/ContentCTA.astro";
import RelatedPages from "../../components/RelatedPages.astro";
import { SITE, ORGANISATION } from "../../consts";
const title = "RPII Explained: Playground Inspector Certification in the UK";
const description =
  "The Register of Play Inspectors International (RPII) is the UK benchmark for playground inspector competence. A complete guide to what RPII is, the inspector grades, how to get certified, and what operators should expect from their inspector.";
const lastUpdatedDisplay = "23 April 2026";
const lastUpdatedISO = "2026-04-23";
const datePublishedISO = "2026-04-23";
const canonical = `${SITE.url.replace(/\/$/, "")}/rpii/`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: datePublishedISO,
  dateModified: lastUpdatedISO,
  author: {
    "@type": "Organization",
    name: ORGANISATION.legalName,
    url: SITE.url,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.url,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonical,
  },
};
const faqs = [
  {
    q: "Is RPII certification legally required to inspect UK playgrounds?",
    a: "No. There is no UK statute that specifies RPII certification as a legal requirement for playground inspection. However, BS EN 1176 requires the annual main inspection to be carried out by a competent independent person, and RPII certification is the de facto UK standard for demonstrating that competence. In procurement practice — local authority contracts, school tenders, housing association frameworks — RPII certification is almost universally specified as a minimum requirement.",
  },
  {
    q: "What is the difference between the RPII inspector grades?",
    a: "Each grade corresponds to a specific inspection type defined in BS EN 1176. The Routine Visual Inspector qualification covers the daily-to-weekly operator-level check. The Operational Inspector qualification covers the more detailed monthly-to-quarterly check. The Annual Inspector qualification covers the independent 12-monthly main inspection — the grade with the most procurement weight. The Post-Installation Inspector qualification covers inspection of newly installed or substantially refurbished equipment and is typically the most demanding route.",
  },
  {
    q: "How do you become RPII-certified?",
    a: "Through an RPII-approved training course followed by assessment. The specific route depends on the grade: Routine Visual and Operational Inspector courses are relatively short and accessible to operator staff; Annual Inspector certification requires more substantial technical training and a formal assessment; Post-Installation Inspector certification typically requires existing inspection experience and technical qualifications. Full current routes and training providers are listed on the RPII website.",
  },
  {
    q: "How often does RPII certification need renewing?",
    a: "RPII certifications are subject to periodic re-registration with associated continuing professional development (CPD) requirements. Inspectors must demonstrate ongoing activity in the field and maintain current knowledge of changes to BS EN 1176 and related standards. Certifications that lapse through missed renewal can be reinstated, but typically with additional requirements. Current renewal periods and CPD requirements are published by RPII.",
  },
  {
    q: "How do I check whether an inspector is genuinely RPII-certified?",
    a: "RPII maintains a public register of certified inspectors. Every certified inspector has a unique registration number, which should appear on every inspection report they issue. Operators commissioning inspections should confirm the inspector&rsquo;s registration via the official register before accepting the work, and should expect the registration number to appear on the final report alongside the inspector&rsquo;s signature.",
  },
  {
    q: "Is CIPE or any other qualification equivalent to RPII?",
    a: "Certified Inspectors of Playground Equipment (CIPE) is a US-rooted qualification with international recognition. Some UK operators accept CIPE as equivalent to RPII, particularly for sites with American play equipment. However, in mainstream UK public procurement RPII remains the expected benchmark, and an RPII qualification is more commonly specified. An inspector with both credentials may have an advantage in mixed-market work.",
  },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---
