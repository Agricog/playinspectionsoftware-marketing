---
/**
 * /about — about page.
 *
 * Trust-building page covering:
 *  1. Who's behind the product (Autaimate / Michael Stevenson)
 *  2. Why InspectVoice exists (origin / problem)
 *  3. The build philosophy (professional-grade from day one, no MVPs)
 *  4. Track record (other Autaimate products)
 *  5. Where and how (Cornwall, UK, direct contact)
 *  6. FAQ addressing procurement concerns (team size, continuity,
 *     ownership, support model)
 *
 * Tone: founder-led authenticity. The one-person operation is a feature
 * for this audience, not a bug — inspectors and operators frequently
 * prefer a UK-based accessible builder over a faceless international SaaS.
 *
 * Content supports E-E-A-T signals (experience, expertise,
 * authoritativeness, trustworthiness) that Google uses to assess the
 * site and its author.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import ContentHero from "../components/ContentHero.astro";
import ContentBreadcrumbs from "../components/ContentBreadcrumbs.astro";
import ContentCTA from "../components/ContentCTA.astro";
import { SITE, ORGANISATION } from "../consts";

const title = "About Autaimate | The Team Behind InspectVoice";
const description =
  "InspectVoice is built by Autaimate, a Cornwall-based UK software operation run by Michael Stevenson. Purpose-built professional tools for UK tradespeople and inspectors, built to a professional standard from day one.";
const lastUpdatedDisplay = "23 April 2026";
const lastUpdatedISO = "2026-04-23";
const datePublishedISO = "2026-04-23";
const canonical = `${SITE.url.replace(/\/$/, "")}/about`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: title,
  description,
  url: canonical,
  publisher: {
    "@type": "Organization",
    name: ORGANISATION.legalName,
    url: SITE.url,
  },
};

// Organization schema — identifies Autaimate as the operator for Google
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: ORGANISATION.legalName,
  url: SITE.url,
  email: ORGANISATION.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: "45 Vicarage Road",
    addressLocality: "St Austell",
    addressRegion: "Cornwall",
    postalCode: "PL24 2PH",
    addressCountry: "GB",
  },
  founder: {
    "@type": "Person",
    name: "Michael Stevenson",
  },
};

const faqs = [
  {
    q: "Is Autaimate a large company?",
    a: "No. Autaimate is a one-person software operation — Michael Stevenson, trading as Autaimate, working from Cornwall. Every line of code, every support email, and every design decision comes from one place. For UK inspectors and operators this is often a feature rather than a limitation — direct access to the builder, no call-centre tier, no overseas support team, no upsell from account managers.",
  },
  {
    q: "What happens to my data and subscription if the business changes hands or closes?",
    a: "Your data is yours throughout. At any point — during a subscription, on cancellation, or in a wind-down scenario — you can export the full archive of your site registers, inspection reports, photographs, and defect history in a structured format. There is no contractual position in which your data is held hostage. Standard subscription terms include notice provisions for any material change to the service, and a reasonable transition window to export data if the service were ever to end.",
  },
  {
    q: "Is Autaimate VC-backed, or self-funded?",
    a: "Self-funded and deliberately so. Autaimate is not VC-backed, has no outside investors, and is not under pressure to grow at a rate that compromises the product or the customer relationship. Subscription revenue funds development directly; the business makes decisions based on what is right for users, not what is required by a growth trajectory.",
  },
  {
    q: "Who owns the intellectual property in the reports I produce with InspectVoice?",
    a: "You do. Reports you produce using InspectVoice are your reports, not ours. Autaimate is a software provider, not a content owner. The intellectual property in your inspection findings, photographs, and written analysis remains entirely yours; Autaimate makes no claim on it and does not use your content for any purpose beyond providing the service to you.",
  },
  {
    q: "How do I get support?",
    a: `Email <a href="mailto:${ORGANISATION.email}">${ORGANISATION.email}</a>. Every support email is read and answered by Michael directly — there is no first-tier support to work through. Response times during UK business hours are typically within a few hours; out-of-hours responses are slower but the same day is normal.`,
  },
  {
    q: "Do you accept feature requests from customers?",
    a: "Yes, and they drive much of the roadmap. Most material improvements to InspectVoice over its history have come from inspectors saying something like &ldquo;on a site last week I needed X and there was no way to do it&rdquo;. Feature requests via email are logged, prioritised against the existing roadmap, and actioned where they fit the product&rsquo;s direction. Direct feedback from working RPII inspectors is the single most valuable input Autaimate receives.",
  },
  {
    q: "Are there other Autaimate products?",
    a: "Yes. Autaimate&rsquo;s other products include CertVoice (voice-driven electrical certification software) and TradeCalcs (calculation tools for UK tradespeople). The common thread is purpose-built professional software for specific UK technical trades — built around the way practitioners actually work rather than retrofitted from generic asset-management tooling.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a.replace(/<[^>]*>/g, "") },
  })),
};
---
<BaseLayout title={title} description={description}>
  <ContentBreadcrumbs
    crumbs={[
      { label: "Home", href: "/" },
      { label: "About" },
    ]}
  />

  <ContentHero
    eyebrow="About"
    title="Built in Cornwall for UK inspection work."
    description="InspectVoice is built by Autaimate, a one-person software operation run by Michael Stevenson. Professional tools for UK tradespeople and inspectors — built to a professional standard from day one, not built up from an MVP."
    lastUpdated={lastUpdatedDisplay}
  />

  <article class="mx-auto max-w-3xl px-6 py-12 sm:py-16">
    <div class="prose prose-slate max-w-none prose-headings:scroll-mt-24 prose-headings:font-semibold prose-headings:text-slate-900 prose-a:text-brand-700 prose-a:no-underline hover:prose-a:underline prose-strong:text-slate-900">
      <h2>The operation</h2>
      <p>
        Autaimate is the trading name under which Michael Stevenson
        builds professional software from Cornwall, United Kingdom. It
        is a deliberately small operation — one developer, one designer,
        one support channel, one person accountable for the whole
        product. There is no head office, no leadership team, no account
        managers, and no international support tier.
      </p>
      <p>
        For the UK playground inspection market this is usually a
        feature rather than a limitation. The people who buy
        InspectVoice — self-employed RPII inspectors, small inspection
        companies, parks officers at councils — almost universally say
        the same thing during onboarding: that they would rather work
        with someone accessible and UK-based than with a
        faceless international SaaS company where every interaction goes
        through a support ticket system.
      </p>

      <h2>Why InspectVoice exists</h2>
      <p>
        The idea came from conversations with working UK RPII
        inspectors. The pattern was consistent: the inspection itself
        was fine — inspectors are technically confident, know BS EN
        1176, know what they are looking at. The problem was everything
        that happened after the inspection. Evenings typing up notes
        into Word. Weekend mornings formatting photographs. Late nights
        before reports were due to clients. For a profession that
        produces its value on-site, far too much time was being spent
        off-site typing.
      </p>
      <p>
        InspectVoice was built around that specific frustration. Voice
        dictation at the equipment, offline-first so signal is never an
        issue, on-device PDF generation so the report is ready before
        the inspector leaves the car park. The product does not try to
        replace the inspector&rsquo;s judgement; it replaces the
        paperwork that surrounded the judgement.
      </p>

      <h2>The build philosophy</h2>
      <p>
        Autaimate&rsquo;s build philosophy is straightforward and
        non-negotiable: build to a professional standard from the
        first line of code. No MVPs, no shortcuts, no &ldquo;we&rsquo;ll
        harden it later&rdquo;, no compromises on security or
        reliability in exchange for shipping speed. The standard is
        what would be acceptable to a UK council procurement team
        reading the security questionnaire on day one.
      </p>
      <p>
        In practice this means:
      </p>
      <ul>
        <li>UK data residency from the beginning, not retrofitted;</li>
        <li>Encryption in transit and at rest, not added after an incident;</li>
        <li>Offline-first architecture, not bolted on to a cloud-only product;</li>
        <li>Multi-tenant isolation at the database layer, not at the application layer;</li>
        <li>Full data export available from day one, not locked behind a premium tier;</li>
        <li>Professional UI and reporting, not MVP styling that will be &ldquo;redesigned when we raise a round&rdquo;.</li>
      </ul>
      <p>
        The philosophy is slower to ship than the Silicon Valley
        alternative. It produces software that does not need apologising
        for.
      </p>

      <h2>Track record</h2>
      <p>
        InspectVoice is not Autaimate&rsquo;s first product. The
        broader Autaimate portfolio includes:
      </p>
      <ul>
        <li>
          <strong>CertVoice</strong> — voice-driven electrical certification
          software for UK electricians. Same core principle as
          InspectVoice: the certificate is written by voice on-site
          rather than typed afterwards.
        </li>
        <li>
          <strong>TradeCalcs</strong> — calculation and estimation tools
          for UK tradespeople, covering the arithmetic that trades
          practitioners do repeatedly and imperfectly on paper.
        </li>
      </ul>
      <p>
        The common thread across the Autaimate portfolio is
        purpose-built professional software for specific UK technical
        trades — built around the way practitioners actually work
        rather than adapted from generic business tooling.
      </p>

      <h2>Where and how</h2>
      <p>
        Autaimate operates from St Austell, Cornwall, United Kingdom.
        All production infrastructure for InspectVoice is held by
        UK-present cloud providers; no data crosses UK jurisdiction
        under normal operation. Support, development, and
        decision-making all happen from the same place.
      </p>
      <p>
        Contact is direct. Every support email, procurement query, and
        feature request goes to
        <a href={`mailto:${ORGANISATION.email}`}>{ORGANISATION.email}</a>
        and is answered by Michael directly. There is no first-tier
        support function to escalate through. Typical response times
        during UK business hours are a few hours; same-day responses are
        normal out of hours too.
      </p>

      <h2>What&rsquo;s next</h2>
      <p>
        The InspectVoice roadmap is driven by three inputs, roughly
        equally weighted: direct feedback from working RPII inspectors
        using the product in the field; the trajectory of BS EN 1176
        and BS EN 1177 as those standards evolve; and the practical
        needs of councils and inspection companies as they professionalise
        their inspection regimes.
      </p>
      <p>
        No grand announcements planned. Just a product that keeps
        getting better at what it already does, shipped by the person
        who built it, to the people who use it every day.
      </p>

      <h2>Questions and procurement</h2>
      <div class="not-prose mt-6 space-y-4">
        {faqs.map((item) => (
          <details class="group rounded-lg border border-slate-200 bg-white p-5 transition hover:border-slate-300">
            <summary class="flex cursor-pointer items-start justify-between gap-4 text-base font-semibold text-slate-900 [&::-webkit-details-marker]:hidden">
              <span>{item.q}</span>
              <svg class="mt-1 h-5 w-5 flex-shrink-0 text-slate-400 transition group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-base leading-relaxed text-slate-600" set:html={item.a} />
          </details>
        ))}
      </div>

      <ContentCTA />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
